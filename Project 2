      "source": [
        "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
        "\n",
        "# 1. Combine the ganga_df and sangam_df DataFrames\n",
        "combined_df = pd.concat([ganga_df, sangam_df], ignore_index=True)\n",
        "\n",
        "# 2. Convert the 'Date' column to datetime objects\n",
        "combined_df['Date'] = pd.to_datetime(combined_df['Date'])\n",
        "\n",
        "# 3. Check for and handle missing values\n",
        "missing_values = combined_df.isnull().sum()\n",
        "print(\"\\n--- Missing values before imputation ---\\n\")\n",
        "print(missing_values)\n",
        "\n",
        "# Impute missing values for numerical columns if any\n",
        "for col in combined_df.select_dtypes(include=['float64']).columns:\n",
        "    if missing_values[col] > 0:\n",
        "        combined_df[col].fillna(combined_df[col].mean(), inplace=True)\n",
        "\n",
        "print(\"\\n--- Missing values after imputation ---\\n\")\n",
        "print(combined_df.isnull().sum())\n",
        "\n",
        "# 4. Encode the 'Status' categorical column using Label Encoding\n",
        "le = LabelEncoder()\n",
        "combined_df['Status_encoded'] = le.fit_transform(combined_df['Status'])\n",
        "\n",
        "# 5. Scale the numerical features\n",
        "# Identify numerical columns for scaling (excluding 'WQI' for now, as it's a target related metric)\n",
        "numerical_cols = ['DO', 'pH', 'ORP', 'Cond', 'Temp', 'WQI']\n",
        "scaler = StandardScaler()\n",
        "combined_df[numerical_cols] = scaler.fit_transform(combined_df[numerical_cols])\n",
        "\n",
        "# 6. Display the head and info of the combined_df after preprocessing\n",
        "print(\"\\n--- Combined_df Head after preprocessing ---\\n\")\n",
        "print(combined_df.head())\n",
        "print(\"\\n--- Combined_df Info after preprocessing ---\\n\")\n",
        "combined_df.info()\n"
